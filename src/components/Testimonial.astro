---
import { Icon } from 'astro-icon/components';

export interface Props {
  quote: string;
  author: string;
  role?: string;
}

const { quote, author, role } = Astro.props;
---

<figure class="glass rounded-3xl p-7 h-full flex flex-col">
  <blockquote class="mt-4 flex-1 text-leao-white/90 leading-relaxed italic">
    “{quote}”
  </blockquote>
  <figcaption class="mt-6 border-t border-white/10 pt-4">
    <div class="font-medium text-leao-white">{author}</div>
    {role && <div class="text-sm text-leao-silver">{role}</div>}
  </figcaption>
</figure>
