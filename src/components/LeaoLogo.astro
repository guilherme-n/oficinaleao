---
/**
 * Marca da Oficina Leão — cabeça de leão estilizada.
 * SVG inline (sem custo de request) com `currentColor` para herdar a cor do pai.
 * Use via `color: <classe tailwind>` no elemento pai (ex.: `text-leao-orange`).
 */
export interface Props {
  class?: string;
  title?: string;
}

const { class: className = '', title = 'Oficina Leão' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  role="img"
  aria-label={title}
  class={className}
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <title>{title}</title>

  <!-- Juba externa (círculo de "raios") -->
  <g opacity="0.9">
    <path d="M32 4 L30 11 L34 11 Z" fill="currentColor" />
    <path d="M46 8 L42 14 L47 15 Z" fill="currentColor" />
    <path d="M18 8 L22 14 L17 15 Z" fill="currentColor" />
    <path d="M56 18 L49 20 L52 24 Z" fill="currentColor" />
    <path d="M8 18 L15 20 L12 24 Z" fill="currentColor" />
    <path d="M58 32 L51 32 L52 36 Z" fill="currentColor" />
    <path d="M6 32 L13 32 L12 36 Z" fill="currentColor" />
    <path d="M54 46 L48 42 L47 47 Z" fill="currentColor" />
    <path d="M10 46 L16 42 L17 47 Z" fill="currentColor" />
  </g>

  <!-- Juba (contorno arredondado) -->
  <path
    d="M32 10
       C 20 10, 12 18, 12 30
       C 12 36, 14 41, 17 45
       C 20 50, 26 54, 32 54
       C 38 54, 44 50, 47 45
       C 50 41, 52 36, 52 30
       C 52 18, 44 10, 32 10 Z"
    fill="currentColor"
    fill-opacity="0.12"
  />

  <!-- Rosto -->
  <path
    d="M22 26
       C 22 22, 26 19, 32 19
       C 38 19, 42 22, 42 26
       L 42 34
       C 42 40, 38 45, 32 45
       C 26 45, 22 40, 22 34 Z"
    fill="currentColor"
    fill-opacity="0.2"
  />

  <!-- Olhos -->
  <circle cx="27.5" cy="29" r="1.6" fill="currentColor" stroke="none" />
  <circle cx="36.5" cy="29" r="1.6" fill="currentColor" stroke="none" />

  <!-- Focinho -->
  <path
    d="M30 35 L34 35 L32 37 Z"
    fill="currentColor"
    stroke="none"
  />

  <!-- Boca -->
  <path d="M32 37 L32 40" />
  <path d="M32 40 C 30 41, 28.5 40.5, 28 39.5" />
  <path d="M32 40 C 34 41, 35.5 40.5, 36 39.5" />

  <!-- Bigodes (sutis) -->
  <path d="M22 34 L18 33" opacity="0.7" />
  <path d="M22 36 L18 37" opacity="0.7" />
  <path d="M42 34 L46 33" opacity="0.7" />
  <path d="M42 36 L46 37" opacity="0.7" />
</svg>
